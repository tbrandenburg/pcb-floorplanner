%%{init: {"theme": "dark"}}%%
flowchart TD
    subgraph TABLE["PCB Floorplanner — Step × Engine × Helper Scripts × DB Writes"]
        direction TB

        S0["<b>Step 0 · User Prompt Intake</b><br/>Engine: LLM<br/>────────────────────────────────────────────────────────<br/>Action: parse free-text prompt, extract intent + target device<br/>Helper Scripts:<br/>  • db_init.py          — create schema, new design_session row<br/>  • db_write_prompt.py  — INSERT into design_sessions<br/>DB Writes:<br/>  ✏ design_sessions(id, prompt, model, created_at)<br/>  ✏ design_versions(id, status=DRAFT, created_at)"]

        S1["<b>Step 1 · Design Capture — BOM + Netlist</b><br/>Engine: LLM + Web Search<br/>────────────────────────────────────────────────────────<br/>Action: web-research BOM, identify ICs, infer nets + requirements<br/>Helper Scripts:<br/>  • web_search.py            — query search API, return structured results<br/>  • db_write_components.py   — INSERT into components<br/>  • db_write_nets.py         — INSERT into nets + net_connections<br/>  • db_write_requirements.py — INSERT into requirements<br/>DB Writes:<br/>  ✏ components(id, version_id, name, type, package, datasheet_url, notes)<br/>  ✏ nets(id, name, type [PWR/GND/SIG/DIFF])<br/>  ✏ net_connections(net_id, comp_id, pin_name)<br/>  ✏ requirements(id, comp_id, key, value)"]

        S2["<b>Step 2 · Board Definition</b><br/>Engine: LLM + Web Search + Python<br/>────────────────────────────────────────────────────────<br/>Action: decide form factor, board size, fixed connectors, keep-outs<br/>Helper Scripts:<br/>  • web_search.py             — lookup form factor specs (HAT, ITX, custom)<br/>  • db_write_board_outline.py — INSERT into board_outline<br/>  • db_write_keepouts.py      — INSERT into keep_out_zones<br/>  • db_write_mount_holes.py   — INSERT into mount_holes<br/>  • validate_board.py         — check outline is closed + non-zero area<br/>DB Writes:<br/>  ✏ board_outline(version_id, width, height, grid_resolution, layer_count)<br/>  ✏ keep_out_zones(id, version_id, x, y, w, h, reason)<br/>  ✏ mount_holes(id, version_id, x, y, diameter)"]

        S3["<b>Step 3 · Component Geometry Resolution</b><br/>Engine: LLM + Web Search + Python<br/>────────────────────────────────────────────────────────<br/>Action: resolve physical dims for every component, fill missing footprints<br/>Helper Scripts:<br/>  • db_read_components.py  — SELECT components missing geometry<br/>  • web_search.py          — lookup datasheet / JEDEC / IPC package dims<br/>  • db_write_geometry.py   — INSERT into component_geometry<br/>  • db_write_pins.py       — INSERT into pins<br/>  • validate_geometry.py   — assert all components have geometry<br/>DB Writes:<br/>  ✏ component_geometry(comp_id, width, height, courtyard_margin, allowed_rotations)<br/>  ✏ pins(comp_id, pin_id, rel_x, rel_y, net_name)"]

        S4["<b>Step 4 · Constraint Derivation</b><br/>Engine: LLM + Web Search<br/>────────────────────────────────────────────────────────<br/>Action: derive NEAR/FAR/FIXED/ALIGN constraints from nets + requirements + PCB rules<br/>Helper Scripts:<br/>  • db_read_nets.py          — SELECT nets + net_connections<br/>  • db_read_requirements.py  — SELECT requirements per component<br/>  • web_search.py            — lookup datasheet layout rules if ambiguous<br/>  • db_write_constraints.py  — INSERT into constraints<br/>DB Writes:<br/>  ✏ constraints(id, version_id, type, comp_a, comp_b, min_dist, max_dist, weight, hard, reason)"]

        S5["<b>Step 5 · Design Lock</b><br/>Engine: Python<br/>────────────────────────────────────────────────────────<br/>Action: validate referential integrity, hash design, set LOCKED<br/>Helper Scripts:<br/>  • validate_fk.py      — check all FKs across tables<br/>  • hash_design.py      — SHA256(components + geometry + constraints)<br/>  • db_lock_version.py  — UPDATE design_versions SET status=LOCKED<br/>  • db_trigger_check.py — verify mutation trigger is active<br/>DB Writes:<br/>  ✏ design_versions(status=LOCKED, hash, locked_at)"]

        S6["<b>Step 6 · Initial Placement</b><br/>Engine: Python<br/>────────────────────────────────────────────────────────<br/>Action: greedy placement — FIXED first, then constraint clusters, then fill<br/>Helper Scripts:<br/>  • db_read_locked.py      — SELECT locked version + geometry + constraints<br/>  • placer_greedy.py       — greedy algorithm, returns placement dict<br/>  • db_write_placements.py — INSERT into placements<br/>  • db_write_grid.py       — INSERT into occupancy_grid<br/>DB Writes:<br/>  ✏ optimization_runs(id, version_id, algorithm, params, timestamp)<br/>  ✏ placements(run_id, comp_id, x, y, rotation, status [FIXED/PLACED])<br/>  ✏ occupancy_grid(run_id, cell_x, cell_y, comp_id)"]

        S7["<b>Step 7 · Optimization</b><br/>Engine: Python<br/>────────────────────────────────────────────────────────<br/>Action: simulated annealing — move / rotate / swap until convergence<br/>Helper Scripts:<br/>  • db_read_placements.py     — SELECT placements + grid for run_id<br/>  • optimizer_annealing.py    — SA loop: propose move, score, accept/reject<br/>  • scorer.py                 — penalty: constraints + overlaps + net length<br/>  • db_write_score_history.py — INSERT per iteration<br/>  • db_write_placements.py    — UPDATE placements after each accepted move<br/>  • db_write_grid.py          — UPDATE occupancy_grid after each accepted move<br/>DB Writes:<br/>  ✏ score_history(run_id, iteration, total_penalty, constraint_penalty, overlap_penalty, net_length_est)<br/>  ✏ placements — updated x, y, rotation per accepted move<br/>  ✏ occupancy_grid — updated cell ownership per accepted move"]

        S8["<b>Step 8 · Scoring + Violation Report</b><br/>Engine: Python<br/>────────────────────────────────────────────────────────<br/>Action: evaluate final placement against all constraints, record violations<br/>Helper Scripts:<br/>  • db_read_final_placement.py — SELECT best iteration from score_history<br/>  • scorer.py                  — full rescore on final placement<br/>  • db_write_violations.py     — INSERT per violated constraint<br/>  • db_write_score.py          — INSERT final summary<br/>DB Writes:<br/>  ✏ violations(run_id, constraint_id, comp_a, comp_b, actual_dist, required_dist, delta)<br/>  ✏ placement_score(run_id, final_penalty, violation_count, hard_violation_count, net_length_total)"]

        S9["<b>Step 9 · LLM Review + Decision</b><br/>Engine: LLM<br/>────────────────────────────────────────────────────────<br/>Action: read violations + scores, diagnose root cause, approve or loop back<br/>Helper Scripts:<br/>  • db_read_violations.py    — SELECT violations JOIN constraints<br/>  • db_read_score_history.py — SELECT score curve for convergence check<br/>  • db_write_review.py       — INSERT review decision<br/>  • db_write_constraints.py  — UPDATE constraints if action=MODIFY<br/>  • db_unlock_version.py     — reset status=DRAFT if constraints change<br/>DB Writes:<br/>  ✏ review_notes(run_id, note, action [APPROVE/MODIFY/RERUN], created_at)<br/>  ✏ constraints — weight / dist updates if action=MODIFY<br/>  ✏ design_versions(status=DRAFT) — only if action=MODIFY"]

        S10["<b>Step 10 · Render + Export</b><br/>Engine: Python<br/>────────────────────────────────────────────────────────<br/>Action: generate all visual and report artifacts<br/>Helper Scripts:<br/>  • db_read_final_state.py — SELECT placements + grid + violations + board_outline<br/>  • render_svg.py          — shapely + svgwrite → floorplan.svg<br/>  • render_png.py          — cairocffi → floorplan.png + heatmap.png<br/>  • render_report.py       — Jinja2 → report.html<br/>  • db_write_artifacts.py  — INSERT file paths<br/>DB Writes:<br/>  ✏ render_artifacts(run_id, type [SVG/PNG/HEATMAP/REPORT], file_path, created_at)"]

        S0 --> S1 --> S2 --> S3 --> S4 --> S5 --> S6 --> S7 --> S8 --> S9 --> S10
        S9 -->|"MODIFY constraints"| S4
        S9 -->|"RERUN optimizer"| S6
    end

